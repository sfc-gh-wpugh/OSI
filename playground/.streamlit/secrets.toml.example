# Streamlit secrets template for OSI Playground running in Snowflake (SiS).
# Copy this file to .streamlit/secrets.toml and fill in the values.
# Do NOT commit secrets.toml to version control.

[osi]
# Snowflake database that contains the demo tables created by setup/snowflake_setup.sql.
database = "MY_DATABASE"

# Schema within that database where the demo tables live.
schema = "PUBLIC"
